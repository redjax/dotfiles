###############################################################
#              Software Initialization & Completions          #
###############################################################
#                                                             #
# This file is sourced by .zshrc and contains initialization  #
# code for various CLI tools and their completions.           #
#                                                             #
# Managing Auto-Added Configuration                           #
# --------------------------------------------                #
# Many installers automatically add lines to ~/.zshrc:        #
#   - NVM, pyenv, cargo, conda, etc.                          #
#                                                             #
# When this happens:                                          #
#   - Check ~/.zshrc for new additions (usually at the end)   #
#   - CUT the added lines from ~/.zshrc                       #
#   - PASTE them into the appropriate section below           #
#   - Wrap them in a conditional check (see examples)         #
#   - Run: chezmoi add ~/.zsh/software_inits.zsh              #
#   - Run: chezmoi apply                                      #
#                                                             #
# Example: If rust installer adds to .zshrc:                  #
#   [ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"    #
#                                                             #
# Move it here as:                                            #
#   if [[ -f "$HOME/.cargo/env" ]]; then                      #
#       source "$HOME/.cargo/env"                             #
#   fi                                                        #
#                                                             #
# Template Variables:                                         #
#   - {{ .chezmoi.homeDir }} = Your home directory            #
#   - Use this for portable paths across machines             #
###############################################################

# Template for new tools:
#
# ##############
# # Tool Name #
# ##############
#
# ## Brief description
# #  Install command or URL
# #  Note if installer adds to .zshrc automatically
# if command -v toolname &>/dev/null; then
#     eval "$(toolname init zsh)"
#     # OR
#     source_if_exists "$HOME/.toolname/init.zsh"
#     # OR
#     export TOOLNAME_VAR="value"
#     path_add "$HOME/.toolname/bin"
# fi
#

## Examples of tools that commonly auto-add to .zshrc:
#
## HOMEBREW (on Linux):
#    Adds: eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
#    Move here wrapped in:
#      if [[ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
#        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
#      fi
#
## NVM:
#    Adds: export NVM_DIR="$HOME/.nvm"
#          [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
#          [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
#    Move here wrapped in:
#      if [[ -d "${HOME}/.nvm" ]]; then
#          export NVM_DIR="${HOME}/.nvm"
#          source_if_exists "$NVM_DIR/nvm.sh"
#          source_if_exists "$NVM_DIR/bash_completion"
#      fi
#

## --------------------------------------------------------------------------------------------

####################
# Helper Functions #
####################

## Add a directory to PATH if it exists and isn't already in PATH
path_add() {
    [[ -d $1 ]] || return
    case ":$PATH:" in
        *":$1:"*) return ;;  # Already in PATH
        *) PATH="$PATH:$1" ;;
    esac
}

## Source a file if it exists
source_if_exists() {
    [[ -f $1 ]] && source "$1"
}

## --------------------------------------------------------------------------------------------

###########
# Chezmoi #
###########
CHEZMOI_ZSH_COMPLETION="{{ .chezmoi.homeDir }}/.local/share/zsh/site-functions/_chezmoi"
if command -v chezmoi &>/dev/null; then
    [[ -f "$CHEZMOI_ZSH_COMPLETION" ]] || chezmoi completion zsh > "$CHEZMOI_ZSH_COMPLETION"
    source_if_exists "$CHEZMOI_ZSH_COMPLETION"
fi

##########
# Direnv #
##########

if command -v direnv >&/dev/null; then
    eval "$(direnv hook zsh)"
fi

#########
# Pyenv #
#########
if command -v pyenv &>/dev/null; then
    path_add "{{ .chezmoi.homeDir }}/.pyenv/bin"

    eval "$(pyenv init -)"
    eval "$(pyenv virtualenv-init -)"
fi

##############################
# NVM (Node Version Manager) #
##############################
if [[ -d "${HOME}/.nvm" ]]; then
    export NVM_DIR="${HOME}/.nvm"
    source_if_exists "$NVM_DIR/nvm.sh" || true
fi

###################
# Astral uv / uvx #
###################
UV_COMPLETION="{{ .chezmoi.homeDir }}/.local/share/zsh/site-functions/_uv"
UVX_COMPLETION="{{ .chezmoi.homeDir }}/.local/share/zsh/site-functions/_uvx"

if command -v uv &>/dev/null; then
    ## Use native Zsh completions
    [[ -f "$UV_COMPLETION" ]] || uv generate-shell-completion zsh > "$UV_COMPLETION"
    [[ -f "$UVX_COMPLETION" ]] || uvx --generate-shell-completion zsh > "$UVX_COMPLETION"

    source_if_exists "$UV_COMPLETION"
    source_if_exists "$UVX_COMPLETION"
fi

########################
# Homebrew / Linuxbrew #
########################
if [[ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

    ## Disable telemetry
    export HOMEBREW_NO_ANALYTICS=1

    path_add "/home/linuxbrew/.linuxbrew/bin"
fi

###############
# Go Language #
###############
path_add "/usr/local/go/bin"
path_add "/opt/gobins"

#################
# Intelli-shell #
#################

INTELLI_HOME="{{ .chezmoi.homeDir }}/.local/share/intelli-shell"
if [[ -d "$INTELLI_HOME" ]]; then
    export INTELLI_HOME

    # Optional hotkeys (uncomment if you want to customize)
    # export INTELLI_SEARCH_HOTKEY="\\C-@"
    # export INTELLI_VARIABLE_HOTKEY="\\C-l"
    # export INTELLI_BOOKMARK_HOTKEY="\\C-b"
    # export INTELLI_FIX_HOTKEY="\\C-x"
    # export INTELLI_SKIP_ESC_BIND=0

    # Optional alias
    # alias is="intelli-shell"

    # Add to PATH using helper function
    path_add "$INTELLI_HOME/bin"

    # Run IntelliShell zsh init
    eval "$(intelli-shell init zsh)"
fi

####################
# Dotnet CLI tools #
####################
if [[ -d "{{ .chezmoi.homeDir }}/.dotnet" ]]; then
    export DOTNET_TOOLS="{{ .chezmoi.homeDir }}/.dotnet/tools"
    path_add "$DOTNET_TOOLS"
fi

#########################
# Terraform completions #
#########################
if command -v terraform &>/dev/null; then
    complete -o nospace -C "$(command -v terraform)" terraform
fi

########################
# Mise CLI activation #
########################

## Mise completions require the 'usage' program https://usage.jdx.dev
#  You can install this with:
#    mise use -g usage

if command -v mise &>/dev/null && command -v usage &>/dev/null; then
    ## Path for local Zsh completions
    MISE_COMPLETION="{{ .chezmoi.homeDir }}/.local/share/zsh/site-functions/_mise"
    mkdir -p "$(dirname "$MISE_COMPLETION")"

    ## Generate completions if missing
    [[ -f "$MISE_COMPLETION" ]] || mise completion zsh > "$MISE_COMPLETION"

    ## Source completions (native Zsh)
    source "$MISE_COMPLETION"

    ## Activate shims
    eval "$(mise activate zsh)"
fi

###############################
# Atuin shell history tracker #
###############################
if command -v atuin &>/dev/null; then
    source_if_exists "{{ .chezmoi.homeDir }}/.atuin/bin/env"
    eval "$(atuin init zsh)" 
fi

#########
# x-cmd #
#########
source_if_exists "{{ .chezmoi.homeDir }}/.x-cmd.root/X"
