## Set path to tmux plugins
setenv -g TMUX_PLUGIN_MANAGER_PATH "{{ .chezmoi.homeDir }}/.tmux/plugins/"

## Automatically install tpm if it's not present.
#  You can also install tpm manually with:
#    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
# if "test ! -d {{ .chezmoi.homeDir }}/.tmux/plugins/tpm" \
#   "run-shell 'git clone https://github.com/tmux-plugins/tpm {{ .chezmoi.homeDir }}/.tmux/plugins/tpm'"

## Only load tpm if it's installed
if-shell 'test -f {{ .chezmoi.homeDir }}/.tmux/plugins/tpm/tpm' \
  'run {{ .chezmoi.homeDir }}/.tmux/plugins/tpm/tpm'
