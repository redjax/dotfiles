version = "1"

[global]
default-command = "backup"
initialize = false
priority = "low"
min-memory = 100

[default]
repository = "local:/path/to/restic-repo"
password-file = "/path/to/restic_pw"
no-error-on-warning = true

[default.forget]
keep-last = 2
keep-hourly = 24
keep-daily = 7
keep-weekly = 4
keep-tag = ["forever"]
prune = true
tag = ["resticprofile"]

[default.backup]
verbose = false
one-file-system = false
read-concurrency = 2
skip-if-unchanged = true
exclude = [".tmp/", ".cache/"]
exclude-file = ["/path/to/resticignore"]
exclude-cloud-files = false
group-by = "host,paths"

[default.check]
schedule = "weekly"
schedule-after-network-online = false
schedule-ignore-on-battery = false
schedule-ignore-on-battery-less-than = 20
read-data = true
with-cache = false

[default.cache]
cleanup = false
max-age = 30
no-size = false



##
# User data (workstation / home directory)
##
[userland]
inherit = "default"

[userland.backup]
verbose = true
source = ["/home/username", "/some/user/owned/path"]
exclude-file = ["/path/to/resticignore", "/path/to/restic_userland_ignore"]

read-concurrency = 4
skip-if-unchanged = true

schedule = "0,6,12,18:00"
schedule-permission = "user"
schedule-priority = "standard"
schedule-lock-mode = "default"
schedule-lock-wait = "15m30s"

[userland.tags]
tags = ["userland"]

##
# System / privileged data
##
[system]
inherit = "default"

[system.backup]
source = [
  "/etc/ssh",
  "/etc/cron.d",
  "/etc/cron.daily",
  "/etc/cron.hourly",
  "/etc/cron.monthly",
  "/etc/crontab",
  "/etc/fstab",
  "/home/username/docker",
  "/home/username/git"
]

schedule = "daily"
schedule-permission = "system"
schedule-priority = "background"

[system.tags]
tags = ["system", "privileged"]

