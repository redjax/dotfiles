#============================================================#
#                     Zsh Configuration                      #
##############################################################
#                                                            #
# Install Zsh (apt install zsh, dnf install zsh, etc),       #
# then set your default shell with:                          #
#   chsh -s $(which zsh) $USER                               #
# Log out and back in to apply                               #
#                                                            #
# Sources software inits & shell completions                 #
# from .zsh/software_inits.zssh if the file exists.          #
#                                                            #
# Sources Oh-My-Zsh configuration if Oh-My-Zsh is installed. #
#                                                            #
#============================================================#

#################
# Shell Options #
#################

## Type a directory name to cd to it
setopt AUTO_CD

## Push dirs onto a stack. Show the stack with dirs -v.
#  Go back to previous directory with cd -.
#  Jump to a specific stack entry with cd ~2 (or whatever stack number).
#  Rotate through dirs with pushd and popd
setopt AUTO_PUSHD

## Prevent the same directory from appearing multiple times
#  in the directory stack
setopt PUSHD_IGNORE_DUPS

## Prevent zsh from printing the directory stack after each change
setopt PUSHD_SILENT

## Advanced pattern matching (use #, ~, ^ for globbing)
setopt EXTENDED_GLOB

## Include dotfiles in * globs without explicit .*
setopt GLOB_DOTS

## Allow # comments in interactive shell
setopt INTERACTIVE_COMMENTS

## cd to variable values (e.g., x=/tmp; cd x)
setopt CDABLE_VARS

## Sort numeric filenames numerically (file1 file2 file10, not file1 file10 file2)
setopt NUMERIC_GLOB_SORT

## Remove pattern if no matches (prevents "no matches found" error)
setopt NULL_GLOB

## Case-insensitive globbing
setopt NO_CASE_GLOB

## Set shell to emacs mode
bindkey -e

## Allow editing a command with CTRL+X + e
autoload -Uz edit-command-line
zle -N edit-command-line

## !IMPORTANT!
#  Only uncomment one of the lines below.
#  If you're using emacs mode (bind -e somewhere in the zsh config),
#  use the first one, otherwise if using vi-mode, use the last 2.
## Emacs mode (bind -e)
bindkey '^Xe' edit-command-line
## Vi mode
# bindkey -M vicmd '^Xe' edit-command-line
# bindkey -M viins '^Xe' edit-command-line

###################
# History Options #
###################

## Remove ALL duplicate entries in history (not just consecutive)
setopt HIST_IGNORE_ALL_DUPS

## Don't show duplicates when searching history
setopt HIST_FIND_NO_DUPS

## Don't save duplicates to history file
setopt HIST_SAVE_NO_DUPS

## If a command starts with a space, it will not be stored in history.
setopt HIST_IGNORE_SPACE

## Save timestamps and duration for each command (like bash HISTTIMEFORMAT)
setopt EXTENDED_HISTORY

## Remove superfluous blanks from history entries
setopt HIST_REDUCE_BLANKS

## Show history expansion before running it (e.g., !! shows command first)
setopt HIST_VERIFY

## Share shell history between all open shells.
setopt SHARE_HISTORY

## Append to history file instead of overwriting.
setopt APPEND_HISTORY

HISTFILE="{{ .chezmoi.homeDir }}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000

################
# PATH Options #
################

## Treat path as a unique array (removes duplicate entries automatically)
typeset -U path

## Add user-controlled site-functions dir for zsh completions
mkdir -p ~/.local/share/zsh/site-functions
fpath=({{ .chezmoi.homeDir }}/.local/share/zsh/site-functions $fpath)

## Initialize completion system with cache optimization
#  Only fully recompile once per day, otherwise use cached version
autoload -Uz compinit
if [[ -n ${HOME}/.zcompdump(#qN.mh+24) ]]; then
    compinit
else
    compinit -C
fi

## Completion system styling
zstyle ':completion:*' menu select                              # Visual menu for completion
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'      # Case-insensitive completion
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"        # Colored completion (uses LS_COLORS)
zstyle ':completion:*' group-name ''                            # Group completions by category
zstyle ':completion:*:descriptions' format '%B%d%b'            # Bold category descriptions
zstyle ':completion:*:warnings' format '%F{red}No matches%f'   # Red warning for no matches

## Enable Bash completions in Zsh
autoload -U +X bashcompinit
bashcompinit

#######################
# Environment Options #
#######################

## XDG config path
export XDG_CONFIG_HOME="{{ .chezmoi.homeDir }}/.config"

## Default file creation permissions
umask 022

## Set TERM value. Ensure terminal supports colors first
if [[ "$TERM" == xterm* || "$TERM" == *-256color || "$TERM" == "xterm-kitty" ]]; then
    COLOR_PROMPT=1
fi

## Set terminal title for xterm-like terminals
if [[ "$TERM" == xterm* || "$TERM" == rxvt* || "$TERM" == xterm-kitty ]]; then
    set_terminal_title() {
        print -Pn "\e]0;%n@%m: %~\a"
    }

    autoload -Uz add-zsh-hook
    add-zsh-hook precmd set_terminal_title
fi

## Iterate through preferred shells, set $EDITOR when one is installed.
for editor in nvim vim nano vi; do
  if (( $+commands[$editor] )); then
    export EDITOR="$editor"
    export VISUAL="$editor"
    break
  fi
done

export PAGER=less
export LESS=-R

## Locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

## Add manpages if /usr/local/man exists
if [[ -d /usr/local/man ]]; then
    export MANPATH="/usr/local/man:$MANPATH"
fi

##################
# Prompt Options #
##################

## Git branch via vcs_info plugin
autoload -Uz vcs_info add-zsh-hook
zstyle ':vcs_info:*' enable git
zstyle ':vcs_info:git:*' formats '(%b)'

## Command duration tracking
format_duration() {
  local total=$1
  local days=$(( total / 86400 ))
  local hours=$(( (total % 86400) / 3600 ))
  local mins=$(( (total % 3600) / 60 ))
  local secs=$(( total % 60 ))
  local str=""

  (( days > 0 )) && str+="${days}d "
  (( hours > 0 )) && str+="${hours}h "
  (( mins > 0 )) && str+="${mins}m "
  str+="${secs}s"

  echo "$str"
}

## Track command start
preexec() {
  cmd_start_time=$SECONDS
}

## Before prompt
precmd() {
  vcs_info
  if [[ -n $cmd_start_time ]]; then
    cmd_duration=$(( SECONDS - cmd_start_time ))
    psvar[1]=$(format_duration $cmd_duration)
    unset cmd_start_time
  else
    psvar[1]="0s"
  fi
}

## Reset exit status at shell start
add-zsh-hook precmd reset_status
reset_status() { (( $? == 0 )) || true }

setopt PROMPT_SUBST

## Custom prompt (disabled if Oh-My-Zsh sets a theme)
#  This will be overridden by Oh-My-Zsh if a theme is configured
if [[ -z "$ZSH_THEME" ]] || [[ "$ZSH_THEME" == "" ]]; then
    ## Prompt with git branch, failure indicator, execution time
    PROMPT='[%1v]%(?..%F{red} X %?%f) %F{green}%n@%m%f:%F{blue}%~%f %F{yellow}${vcs_info_msg_0_}%f%# '
fi

###########
# Aliases #
###########

alias reload='exec zsh'
alias mkdir='mkdir -pv'
alias getchmod="stat --format '%a'"

## ls
alias ll='ls -lah'
alias l='ls -CF'

## grep
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

## Neovim
alias nvimi="nvim --headless '+Lazy sync +qa'"
alias nvimu="nvim --headless '+Lazy update +qa'"
alias snvim="sudo -E nvim"

## Lazygit
alias lg='lazygit'

## Terraform
alias tf='terraform'
alias tg='terragrunt'

## Misc
alias myip='curl -s http://ipecho.net/plain; echo'

##################
# Software inits #
##################

## Source Oh My Zsh if it's installed
if [[ -f "{{ .chezmoi.homeDir }}/.zsh/oh-my-zsh.zsh" ]] && [[ -f "{{ .chezmoi.homeDir }}/.oh-my-zsh/oh-my-zsh.sh" ]]; then
    source "{{ .chezmoi.homeDir }}/.zsh/oh-my-zsh.zsh"
    source "{{ .chezmoi.homeDir }}/.oh-my-zsh/oh-my-zsh.sh"
fi

## Source ~/.zsh/software_inits.zsh if it exists
[[ -f "{{ .chezmoi.homeDir }}/.zsh/software_inits.zsh" ]] && source "{{ .chezmoi.homeDir }}/.zsh/software_inits.zsh"

##########
# Keymap #
##########

## Fix Delete / Backspace in Emacs mode
#  i.e. if `bindkey -e` is set somewhere in this config
bindkey '^?' backward-delete-char   # Backspace key
bindkey '^[[3~' delete-char         # Delete key

## CTRL+Backspace deletes a whole word
bindkey '^H' backward-kill-word   # Some terminals send ^H
bindkey '^[^?' backward-kill-word # Some terminals send ESC + DEL

## Home and End keys
bindkey '^[[H' beginning-of-line    # Home key
bindkey '^[[F' end-of-line          # End key
bindkey '^[[1~' beginning-of-line   # Home key (alternative)
bindkey '^[[4~' end-of-line         # End key (alternative)

## Page Up / Page Down for history search
bindkey '^[[5~' history-search-backward  # Page Up
bindkey '^[[6~' history-search-forward   # Page Down

## CTRL+Arrow keys for word navigation
#  Only enabled when NOT inside a multiplexer (Zellij, tmux, etc.)
#  This prevents conflicts with multiplexer keybindings
if [[ -z "$ZELLIJ" ]] && [[ -z "$TMUX" ]]; then
    bindkey '^[[1;5D' backward-word     # CTRL+Left arrow
    bindkey '^[[1;5C' forward-word      # CTRL+Right arrow
    bindkey '^[OD' backward-word        # CTRL+Left arrow (alternative)
    bindkey '^[OC' forward-word         # CTRL+Right arrow (alternative)
fi
