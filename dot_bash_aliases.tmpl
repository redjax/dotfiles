## ls aliases
{{ if eq .chezmoi.os "linux" -}}
alias ll='ls -la --color=auto'
alias lsa="ls -a --color=auto"
alias lsl="ls -l --color=auto"
alias lsla="ls -la --color=auto"

alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
{{ else if eq .chezmoi.os "darwin" -}}
alias ls="ls -G"
alias lsa="ls -a -G"
alias lsl="ls -l -G"
alias lsla="ls -la -G"
{{ end }}
## get dir/file's chmod
alias getchmod="stat --format '%a' "

## Use rsync instead of cp if installed
if command -v rsync -v 2>&1 /dev/null; then
  alias cp='rsync --progress -auHxvz '
fi

## Source .bash_dots_loader file
if [[ -f ~/.bash_loader ]]; then
  . ~/.bash_loader
fi
