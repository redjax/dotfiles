alias bashrcs=". ~/.bashrc"
alias editalias='$EDITOR ~/.bash_aliases'
alias editaliases='$EDITOR ~/.bash_aliases'

alias dc='docker-compose '
alias sdocker="sudo docker"
alias sdocker-compose="sudo docker-compose"
alias sdc="sudo docker-compose"

alias ls='ls --color=auto'
alias lsa='ls -a --color=auto'
alias lsl='ls -l --color=auto'
alias lsn='ls -n --color=auto'
alias lsp='ls -p --color=auto'
alias lsla='ls -la --color=auto'
alias lsal='ls -la --color=auto'
alias lsln='ls -ln --color=auto'
alias lsnl='ls -ln --color=auto'
alias lsan='ls -an --color=auto'
alias lsna='ls -an --color=auto'
alias lsap='ls -psa --color=auto'
alias lspa='ls -psa --color=auto'
alias lslp='ls -pl --color=auto'
alias lspl='ls -pl --color=auto'
alias lsnp='ls -pn --color=auto'
alias lspn='ls -pn --color=auto'
alias lsapn='ls -nap --color=auto'
alias lsanp='ls -nap --color=auto'
alias lspan='ls -nap --color=auto'
alias lspna='ls -nap --color=auto'
alias lslnap='ls -lnap --color=auto'
alias lslnpa='ls -lnap --color=auto'
alias lslapn='ls -lnap --color=auto'
alias lslanp='ls -lnap --color=auto'
alias lslpan='ls -lnap --color=auto'
alias lslpna='ls -lnap --color=auto'
alias lslna='ls -lnsa --color=auto'
alias lsnla='ls -lnsa --color=auto'
alias lsanl='ls -lnsa --color=auto'
alias lsaln='ls -lnsa --color=auto'
alias lslnap='ls -lnap --color=auto'
alias lslnpa='ls -lnap --color=auto'
alias lslapn='ls -lnap --color=auto'
alias lslanp='ls -lnap --color=auto'
alias lslpan='ls -lnap --color=auto'
alias lslpna='ls -lnap --color=auto'

alias mkdir='mkdir -pv'

alias grep='grep --color'

alias tmux="TERM=screen-256color-bce tmux"
alias tmuxls='tmux ls'
alias tmuxa='tmux a -t $1'

alias nvimi="nvim --headless +PlugInstall +qa"
alias nvimu="nvim --headless +PlugUpdate +qa"
alias snvim="sudo -E nvim"

export EDITOR='nvim'
